  { name: '서귀포시',      lat: 33.2534, lng: 126.5600 },
  { name: '제주 성산',     lat: 33.4614, lng: 126.9199 },
  // 부산
  { name: '부산 해운대',   lat: 35.1631, lng: 129.1635 },
  { name: '부산 서면',     lat: 35.1579, lng: 129.0586 },
  { name: '부산 남포동',   lat: 35.0976, lng: 129.0319 },
